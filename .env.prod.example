# Production Environment Variables for Docker Compose
# Copy this to .env.prod and fill in your actual values

# Database
POSTGRES_PASSWORD=your_super_secure_database_password_here

# Directus
DIRECTUS_SECRET=your_super_long_directus_secret_32_chars_min
ADMIN_EMAIL=admin@muuttokone.fi  
ADMIN_PASSWORD=your_admin_password_here
DIRECTUS_PUBLIC_URL=https://your-directus.up.railway.app
DIRECTUS_STATIC_TOKEN=your_directus_api_token_here

# Frontend
SITE_URL=https://muuttokone.fi
NEXTAUTH_SECRET=your_nextauth_secret_32_characters_minimum
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email (configure with your provider)
EMAIL_SERVER_HOST=smtp.your-provider.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_email@domain.com
EMAIL_SERVER_PASSWORD=your_email_password
EMAIL_FROM=noreply@muuttokone.fi
