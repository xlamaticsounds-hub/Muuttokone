// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

/**
 * ===== Enums =====
 */

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  SCHEDULED
  PROPOSAL_SENT
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  QUICK_QUOTE
  STEP_FORM
  WEBSITE
  PHONE
  EMAIL
  REFERRAL
  ADS
  OTHER
}

/**
 * ===== Core =====
 */

model Contact {
  id          String  @id @default(cuid())
  // Person/company
  firstName   String?
  lastName    String?
  companyName String?
  email       String? // keep non-unique to allow multiple leads per same email (adjust to @unique if you prefer upsert-only)
  phone       String?
  notes       String?

  // Address (flat for easy forms)
  street     String?
  postalCode String?
  city       String?
  region     String?
  country    String? @default("FI")

  // Consent
  gdprConsentAt DateTime?

  // Tags
  tags String[]

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  leads Lead[]
}

model Lead {
  id        String  @id @default(cuid())
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId String

  status LeadStatus @default(NEW)
  source LeadSource @default(WEBSITE)

  // Move details
  formData      Json?
  requestedDate DateTime?
  fromAddress   String?
  toAddress     String?
  volumeM3      Float?
  notes         String?
  
  // New structured fields
  floor         Int?
  hasElevator   Boolean?
  squareMeters  Float?
  boxCount      Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ✅ indexes
  @@index([contactId])
  @@index([status])
  @@index([source])
}

model Log {
  id         String  @id @default(cuid())
  // polymorphic pointer
  entityType String // "Lead" | "Contact" | "Customer" | "Project" | "Task"
  entityId   String
  action     String // "lead.create", "lead.update", "project.schedule", etc.
  message    String?
  data       Json?
  ip         String?

  actorId   String? // User.id if available
  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

/**
 * ===== Blog =====
 */

model Post {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String?   @db.Text
  published       Boolean   @default(false)
  featuredImage   String?
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Basic author info (since no User model is in DB yet)
  authorName      String?   @default("Muuttokone-tiimi")

  // Relations
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?

  @@index([slug])
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model PageContent {
  id        String   @id @default(cuid())
  slug      String   @unique // e.g., "home", "palvelut"
  title     String
  metadata  Json?    // For page-specific SEO
  sections  Json     // The "Lego" blocks: Array of { id, type, props: { text, images, etc } }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Image {
  id        String   @id @default(cuid())
  url       String   @unique // Public GCS URL
  name      String   // Original filename
  bucket    String   // GCS bucket name
  path      String   // Path within bucket
  type      String   // mime type
  size      Int      // bytes
  alt       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([url])
}