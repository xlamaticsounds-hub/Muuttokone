// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/* ===== Enums ===== */

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  SCHEDULED
  PROPOSAL_SENT
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  QUICK_QUOTE
  STEP_FORM
  WEBSITE
  PHONE
  EMAIL
  REFERRAL
  ADS
  OTHER
}

enum ProjectStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/* ===== Auth (use your existing NextAuth models).
   If you already have User/Account/Session/VerificationToken, keep those and delete this User. */

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ===== Core ===== */

model Contact {
  id          String   @id @default(cuid())
  // Person/company
  firstName   String?
  lastName    String?
  companyName String?
  email       String?  // keep non-unique to allow multiple leads per same email (adjust to @unique if you prefer upsert-only)
  phone       String?
  notes       String?

  // Address (flat for easy forms)
  street      String?
  postalCode  String?
  city        String?
  region      String?
  country     String?  @default("FI")

  // Consent
  gdprConsentAt DateTime?

  // Tags
  tags       String[]

  // Audit
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  // Relations
  leads      Lead[]
  customers  Customer[]
}

model Lead {
  id            String      @id @default(cuid())
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId     String

  status        LeadStatus  @default(NEW)
  source        LeadSource  @default(WEBSITE)
  priority      Priority?

  estimatedValue Int?
  currency       String?    @default("EUR")
  formData      Json?
  requestedDate DateTime?
  fromAddress   String?
  toAddress     String?
  volumeM3      Float?
  floorsFrom    Int?
  floorsTo      Int?
  elevatorFrom  Boolean?
  elevatorTo    Boolean?
  packingNeeded Boolean?
  heavyItems    String?
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  projects      Project[]

  // ✅ indexes
  @@index([contactId])
  @@index([status])
  @@index([source])
}

model Project {
  id           String        @id @default(cuid())
  lead         Lead?         @relation(fields: [leadId], references: [id])
  leadId       String?       @unique
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId   String

  title        String
  status       ProjectStatus @default(DRAFT)
  startAt      DateTime?
  endAt        DateTime?
  priceCents   Int?
  currency     String?       @default("EUR")
  crewSize     Int?
  vehicleNotes String?
  instructions String?
  fromAddress  String?
  toAddress    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  tasks        Task[]

  // ✅ indexes
  @@index([customerId])
  @@index([status])
}

model Task {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String

  title       String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  priority    Priority? @default(MEDIUM)
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ✅ index
  @@index([projectId])
}


model Customer {
  id          String   @id @default(cuid())
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId   String   @unique

  customerCode String? @unique
  billingNotes String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  projects    Project[]
}

model Log {
  id          String   @id @default(cuid())
  // polymorphic pointer
  entityType  String   // "Lead" | "Contact" | "Customer" | "Project" | "Task"
  entityId    String
  action      String   // "lead.create", "lead.update", "project.schedule", etc.
  message     String?
  data        Json?
  ip          String?

  actorId     String?  // User.id if available
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
